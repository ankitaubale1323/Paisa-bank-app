# Skip node_modules — Docker installs these fresh inside the container
node_modules

# Skip log files
*.log
npm-debug.log*

# Skip environment files — these are passed via docker-compose env_file
.env
.env.local

# Skip git files
.git
.gitignore

# Skip editor config files
.vscode
.idea
*.swp

# Skip OS files
.DS_Store
Thumbs.db


# Skip Docker files themselves
Dockerfile
.dockerignore